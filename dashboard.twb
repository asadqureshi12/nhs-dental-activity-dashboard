                <zone forceUpdate='true' h='10000' id='20' type-v2='text' w='98400' x='800' y='5875'>
                  <formatted-text>
                    <run bold='true' fontcolor='#606b76' fontsize='10'>This dashboard summarizes NHS dental practice activity and efficiency. </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#606b76' fontsize='10'>The Patient Mix bar chart shows the proportion of children, non-paying, and paying adult patients. </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#606b76' fontsize='10'>The Treatment Band Distribution chart shows the types of treatments delivered across practices. </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#606b76' fontsize='10'>The Efficiency Scatter Plot compares total workload (COT) with average UDA per treatment, highlighting high- and low-efficiency practices.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
